{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "620px",
			"wideSize": "1000px"
		},
		"color": {
			"palette": [
				{
					"color": "#000000",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#ffffff",
					"name": "Background",
					"slug": "background"
				}
			]
		},
		"typography": {
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": false,
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": false,
					"name": "Large",
					"size": "1.5rem",
					"slug": "large"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|background",
			"text": "var:preset|color|primary"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|medium",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"top": "0px",
				"right": "var:preset|spacing|40",
				"bottom": "0px",
				"left": "var:preset|spacing|40"
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}
