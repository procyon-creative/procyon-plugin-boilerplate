{
  "name": "@procyon-creative/plugin-boilerplate",
  "version": "1.1.0",
  "description": "A WordPress block plugin boilerplate template for @wordpress/create-block with auto-update support and GitHub Actions releases.",
  "keywords": [
    "wordpress",
    "plugin",
    "boilerplate",
    "create-block",
    "block-editor",
    "gutenberg"
  ],
  "homepage": "https://github.com/procyon-creative/procyon-plugin-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/procyon-creative/procyon-plugin-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/procyon-creative/procyon-plugin-boilerplate.git"
  },
  "license": "GPL-2.0-or-later",
  "author": "Procyon Creative",
  "bin": {
    "create-block": "./index.js"
  },
  "files": [
    "index.js",
    "lib/",
    "templates/"
  ],
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.2.3"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@wordpress/scripts": "^32.2.0",
    "commander": "^14.0.3",
    "minimist": "^1.2.8"
  },
  "scripts": {
    "lint:js": "wp-scripts lint-js",
    "test": "jest",
    "test:a11y": "start-server-and-test 'http-server docs -p 8765 -s' http://127.0.0.1:8765 'axe http://127.0.0.1:8765/ --exit'",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "start-server-and-test": "^3.0.5"
  }
}
