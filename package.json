{
  "name": "@procyon-creative/plugin-boilerplate",
  "version": "1.1.0",
  "description": "A WordPress block plugin and theme boilerplate template for @wordpress/create-block with auto-update support and GitHub Actions releases.",
  "keywords": [
    "wordpress",
    "plugin",
    "theme",
    "boilerplate",
    "create-block",
    "block-editor",
    "gutenberg",
    "block-theme"
  ],
  "homepage": "https://github.com/procyon-creative/procyon-plugin-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/procyon-creative/procyon-plugin-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/procyon-creative/procyon-plugin-boilerplate.git"
  },
  "license": "GPL-2.0-or-later",
  "author": "Procyon Creative",
  "bin": {
    "create-block": "./index.js"
  },
  "files": [
    "index.js",
    "lib/",
    "templates/"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
	"dependencies": {
		"@inquirer/prompts": "^8.5.2",
		"@wordpress/scripts": "^32.5.0",
		"commander": "^15.0.0",
		"minimist": "^1.2.8",
		"mustache": "^4.2.0"
	},
	"scripts": {
		"lint:js": "wp-scripts lint-js",
		"test": "jest",
		"test:e2e": "node e2e/setup-scaffold.js && npx playwright test",
		"test:e2e:setup": "node e2e/setup-scaffold.js",
		"test:e2e:playwright": "npx playwright test",
		"test:a11y": "start-server-and-test 'http-server docs -p 8765 -s' http://127.0.0.1:8765 'axe http://127.0.0.1:8765/ --exit'",
		"prepare": "husky || true"
	},
	"jest": {
		"testPathIgnorePatterns": [
			"/e2e/"
		]
	},
	"devDependencies": {
		"@axe-core/cli": "^4.11.3",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@playwright/test": "^1.61.0",
		"http-server": "^14.1.1",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"start-server-and-test": "^3.0.11"
	}
}
